#!/usr/bin/env bash
# Pre-push hook : empêche de pousser du code qui ne compile pas
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File "$ROOT/scripts/verify.ps1" -Quick
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$ROOT/scripts/verify.ps1" -Quick
else
  echo "PowerShell requis pour verify.ps1"
  exit 1
fi
